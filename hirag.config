# =========================
# HiRAG Runner Configuration
# =========================

# -------------------------
# Input / Workspace
# -------------------------
input_dir=demo_v2_norm
working_dir=hirag_workdir
limit=0
env_file=.env
skip_normalization=true

# -------------------------
# OpenAI API
# -------------------------
openai_api_key=
openai_base_url=

# LLM model
chat_model=gpt-4o-mini

# Embedding model
embedding_model=text-embedding-3-small
embedding_dim=1536

# -------------------------
# Retrieval Modes
# -------------------------
enable_llm_cache=true
enable_hierachical_mode=true
enable_naive_rag=false

# -------------------------
# Embedding Performance
# -------------------------
embedding_batch_num=32
embedding_func_max_async=32
chunk_token_size=1800
chunk_overlap_token_size=40

# -------------------------
# Graph Extraction
# -------------------------
entity_extract_max_gleaning=0
best_model_max_async=12
insert_batch_size=16

# -------------------------
# Query Generation
# -------------------------
temperature=0.4