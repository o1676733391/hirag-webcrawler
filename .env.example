# Select provider family: gemini or openai
MD4GK_PROVIDER=gemini

# Optional full LiteLLM model override. If set, this wins.
MD4GK_MODEL=

# Provider-specific default models used when MD4GK_MODEL is empty.
MD4GK_GEMINI_MODEL=gemini/gemini-flash-latest
MD4GK_OPENAI_MODEL=openai/gpt-4o-mini

# Provider-specific API keys.
# For Gemini you can use either MD4GK_GEMINI_API_KEY, GEMINI_API_KEY, or GOOGLE_API_KEY.
MD4GK_GEMINI_API_KEY=

# For OpenAI you can use either MD4GK_OPENAI_API_KEY or OPENAI_API_KEY.
MD4GK_OPENAI_API_KEY=
